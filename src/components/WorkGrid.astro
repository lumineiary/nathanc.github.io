---
import WorkCard from "@components/WorkCard.astro";
import type { PhotographyEntry } from "@lib/content";

interface Props {
  items: PhotographyEntry[];
}

const { items } = Astro.props;
---

<div class="work-grid">
  {items.map((item, index) => <WorkCard item={item} large={index === 0} />)}
</div>
